{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tesseracs.dev/schemas/module-interface.schema.json",
  "title": "Tesseracs UI Module Interface",
  "description": "Contract for publishable UI modules.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "module_id",
    "version",
    "display_name",
    "ui",
    "state",
    "events",
    "actions",
    "compatibility"
  ],
  "properties": {
    "kind": {
      "const": "ui_module"
    },
    "module_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{1,62}$"
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:[-+][0-9A-Za-z.-]+)?$"
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "ui": {
      "type": "object",
      "additionalProperties": false,
      "required": ["icon", "category", "render_target", "props_schema"],
      "properties": {
        "icon": { "type": "string" },
        "category": { "type": "string" },
        "render_target": {
          "enum": ["chat_block", "side_panel", "full_panel", "inline"]
        },
        "props_schema": { "type": "object" },
        "preview_image": { "type": "string" }
      }
    },
    "state": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope", "shape_schema"],
      "properties": {
        "scope": {
          "enum": ["session", "project", "user", "ephemeral"]
        },
        "shape_schema": { "type": "object" }
      }
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "payload_schema"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "payload_schema": { "type": "object" }
        }
      },
      "uniqueItems": true
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "input_schema"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "input_schema": { "type": "object" }
        }
      },
      "uniqueItems": true
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["theme_support", "mobile_support", "a11y_level", "min_host_version"],
      "properties": {
        "theme_support": { "enum": ["light", "dark", "both"] },
        "mobile_support": { "enum": ["none", "partial", "full"] },
        "a11y_level": { "enum": ["none", "basic", "wcag-aa", "wcag-aaa"] },
        "min_host_version": { "type": "string" }
      }
    }
  }
}
